# WordOps multitenancy maintenance include for {{domain}}
# Generated {{generated_at}}
# Dropped into /var/www/{{domain}}/conf/nginx/ ; loaded by the main vhost.
set $wo_mt_maintenance 1;
{{#loopback_bypass}}
if ($realip_remote_addr = 127.0.0.1) {
    set $wo_mt_maintenance 0;
}
if ($realip_remote_addr = "::1") {
    set $wo_mt_maintenance 0;
}
{{/loopback_bypass}}

if ($wo_mt_maintenance = 1) {
    return 503;
}

error_page 503 @wo_mt_maintenance_page;

location @wo_mt_maintenance_page {
    add_header Retry-After "{{retry_after_seconds}}" always;
    add_header Cache-Control "no-store, no-cache, must-revalidate" always;
    root {{site_htdocs}};
    try_files /maintenance.html =503;
}
